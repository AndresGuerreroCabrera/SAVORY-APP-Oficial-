{
  "expo": {
    "name": "Savory",
    "slug": "savory",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "savory",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.jpeg",
      "backgroundColor": "#FF6B5F",
      "resizeMode": "contain"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
